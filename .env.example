# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=skillbuild_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# NeonDB (vector/market data store)
NEON_DATABASE_URL=your-neon-connection-string-here

# AI API Keys
GROQ_API_KEY=your-groq-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here   # https://aistudio.google.com/app/apikey

# AWS S3 (optional — local file storage used if not set)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# YouTube Data API (optional — enriches roadmap resources)
YOUTUBE_API_KEY=your-youtube-api-key

# Udemy API (optional)
UDEMY_CLIENT_ID=your-udemy-client-id
UDEMY_CLIENT_SECRET=your-udemy-client-secret

# Redis (optional — falls back to in-memory cache if not set)
REDIS_URL=redis://localhost:6379/1
